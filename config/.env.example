# ================================================================
# WtE Digital Twin 6.6 MW — Environment Variables
# Copy this file to config/.env and fill in real values
# NEVER commit config/.env to git
# ================================================================

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...    # service_role key (backend only)
SUPABASE_ANON_KEY=eyJhbGci...       # anon key (frontend)

# --- Ovation OPC-UA (Emerson DCS) ---
OPC_ENDPOINT=opc.tcp://192.168.1.100:4840   # fill in from Ovation EWS
OPC_NAMESPACE=2                              # Ovation default namespace index
OPC_USERNAME=                                # leave blank if no auth
OPC_PASSWORD=
POLL_INTERVAL_S=5                            # polling interval in seconds

# --- Ovation PHD Historian ---
PHD_REST_URL=http://192.168.1.101:8080/api  # PHD REST endpoint
PHD_USERNAME=
PHD_PASSWORD=

# --- MATLAB Engine / Production Server ---
MATLAB_ENGINE_PORT=9200
MATLAB_BASE_PATH=/Users/udomsakkaewsiri/Documents/Work in Process/05_Applications/WtE-DigitalTwin-6.6MW/matlab

# --- App ---
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3001
LOG_LEVEL=INFO
