# ================================================================
# WtE Digital Twin 6.6 MW — Environment Variables Template
# Copy this file:
#   cp config/.env.example config/.env
# Fill in real values — NEVER commit config/.env to git
# ================================================================

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>   # backend only, never expose to frontend
SUPABASE_ANON_KEY=<anon_key>             # safe for frontend

# ── Ovation OPC-UA (Emerson DCS) ──────────────────────────────────
OPC_ENDPOINT=opc.tcp://192.168.1.100:4840
OPC_NAMESPACE=2
OPC_USERNAME=
OPC_PASSWORD=
POLL_INTERVAL_S=5

# ── MATLAB ────────────────────────────────────────────────────────
MATLAB_BIN=/usr/local/bin/matlab
MATLAB_SCRIPT=matlab/core/s00_run.m
MATLAB_ENGINE_PORT=9200

# ── FastAPI ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
